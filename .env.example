# ================================================
# Mindstorm IT Helpdesk — Environment Variables
# Copy this file to .env and fill in your values
# ================================================

# ── Django ──────────────────────────────────────
DEBUG=False

# Generate with: python3 -c "import secrets; print(secrets.token_hex(50))"
DJANGO_SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_STRING

# Add your server IP here (comma separated, no spaces)
ALLOWED_HOSTS=localhost,127.0.0.1,YOUR_SERVER_IP

# ── Admin Account ────────────────────────────────
# Created automatically on first startup
ADMIN_EMAIL=adnan.akram@mindstormstudios.com
ADMIN_PASSWORD=Adnan@Helpdesk2026!

# ── Google OAuth ────────────────────────────────
# Get from: https://console.cloud.google.com
# Redirect URI to add: http://YOUR_SERVER_IP/accounts/google/login/callback/
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Email domain restriction (only this domain can log in)
ALLOWED_EMAIL_DOMAIN=mindstormstudios.com

# ── URLs ─────────────────────────────────────────
# Your server IP or domain — no trailing slash
FRONTEND_URL=http://YOUR_SERVER_IP
CORS_ALLOWED_ORIGINS=http://YOUR_SERVER_IP
CSRF_TRUSTED_ORIGINS=http://YOUR_SERVER_IP

# ── Slack (Optional — add later) ────────────────
# Get from: https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_IT_CHANNEL=#it-helpdesk

# ── Security (set to True if using HTTPS) ────────
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Slack Incoming Webhook URL
# Create one at: https://api.slack.com/messaging/webhooks
# 1. Go to https://api.slack.com/apps → Create New App → From Scratch
# 2. Name it "Mindstorm IT Desk", pick your workspace
# 3. Go to "Incoming Webhooks" → Activate → Add New Webhook
# 4. Pick the channel (e.g. #it-support) → Copy the URL below
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXXX/XXXXX/XXXXX
